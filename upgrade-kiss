#!/usr/bin/env bash

# Upgrade a Kiss-based application with the latest version of Kiss.

if [ $# -ne 1 ]; then
	echo
	echo '* * * This is to be run from the virgin Kiss clone and not your application project directory. * * *'
	echo
	echo Usage: $0 path-to-kiss-based-application
	echo
	echo You should back up your system before running this.
	exit
fi
shopt -s nullglob
if [ ! -d "$1" ]; then
	echo Directory "$1" does not exist.
	exit
fi
./bld realclean
pushd "$1"
./bld realclean
popd
rsync -av libs/ "$1"/libs
rsync -av --delete manual/ "$1"/manual
rsync -av --delete src/main/core/ "$1"/src/main/core
rsync -av --delete src/test/core/ "$1"/src/test/core
rsync -av --delete src/main/frontend/kiss/ "$1"/src/main/frontend/kiss
rm -rf "$1"/src/main/frontend/WEB-INF "$1"/src/main/frontend/META-INF
rsync -av src/main/frontend/lib/ "$1"/src/main/frontend/lib
rsync -av bld "$1"
rsync -av bld.cmd "$1"
rsync -av build.xml "$1"
rsync -av make-frontend "$1"
rsync -av make-frontend.cmd "$1"
rsync -av new-app "$1"
rsync -av new-app.cmd "$1"
rsync -av remove-backend "$1"
rsync -av remove-backend.cmd "$1"
rsync -av remove-frontend "$1"
rsync -av remove-frontend.cmd "$1"
rsync -av SimpleWebServer.jar "$1"
rsync -av serve "$1"
rsync -av serve.cmd "$1"
rsync -av view-log "$1"
rm -f "$1"/upgrade-*

# Files the framework owns but cannot safely sync because they are
# typically customized per-application.  List them so the operator
# can manually diff and merge any framework-side changes.
MANUAL_MERGE_FILES=(
    "src/main/precompiled/Tasks.java"
)

echo
echo "============================================================"
echo "                  MANUAL MERGE MAY BE REQUIRED"
echo "============================================================"
echo
echo "The following file(s) live in your application but are framework-"
echo "controlled.  Compare each one against the version in this Kiss"
echo "clone and merge any framework-side changes into your copy:"
echo
for f in "${MANUAL_MERGE_FILES[@]}"; do
    echo "    $f"
done
echo
echo "Quick diff command (run from the Kiss clone):"
echo
for f in "${MANUAL_MERGE_FILES[@]}"; do
    echo "    diff -u \"$1/$f\" $f"
done
echo
echo "============================================================"
echo

